#!/bin/sh
# randmac - generate random MAC address(es)

HELP=$(cat <<EOF
randmac - generate random MAC address(es)
Usage: randmac [options]
  -O 54:42:12   MAC vendor prefix (OUI)
  -n 1          number of generated MAC addresses
  -E MAC,MAC... exclude given MAC address(es)
  -w            print generated MAC address(es) and wait
  -h            show this message and exit
EOF
)

OUI=54:42:12
N=1
WAIT=
EXCL=
while getopts :O:n:E:wh OPT ; do
	case "$OPT" in
	O)	OUI=$OPTARG ;;
	n)	N=$OPTARG ;;
	E)	EXCL=$(echo "$OPTARG" | tr '[:upper:]' '[:lower:]') ;;
	w)	WAIT=1 ;;
	h)	echo "$HELP" ; exit ;;
	*)	echo >&2 "error: unknown option -$OPTARG" ; exit 1 ;;
	esac
done

ADD=6
OLDIFS=$IFS ; IFS=':' ; for _ in $OUI ; do
	ADD=$(( ADD - 1 ))
done ; IFS=$OLDIFS

while [ "$N" -gt 0 ]; do
	MAC="$OUI"
	I=$ADD
	while [ "$I" -gt 0 ]; do
		[ "$MAC" = "" ] && D= || D=:
		MAC=$MAC$(printf "$D%02x" "$(dd if=/dev/urandom bs=1 count=1 2>/dev/null | od -An -tu1 | sed 's/ //g')")
		I=$(( I - 1 ))
	done
	if [ -n "$EXCL" ]; then
		SKIP=
		OLDIFS=$IFS ; IFS=',' ; for EMAC in $EXCL ; do
			if [ "$EMAC" = "$MAC" ]; then
				SKIP=1
				break
			fi
		done ; IFS=$OLDIFS
		[ -n "$SKIP" ] && continue
	fi

	echo "$MAC"
	N=$(( N - 1 ))
done
if [ -n "$WAIT" ]; then
	echo >&2 "Press ENTER to continue..."
	read -r _
fi
