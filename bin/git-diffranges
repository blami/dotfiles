#!/bin/sh
# git-diffranges - print all modified line ranges in a diff

HELP=$(cat <<EOF
git diffranges - print all modified line ranges in a diff
Usage: git diffranges [options] [FILE FILE...]
  -c COMMIT     diff between HEAD and COMMIT (default: main)
EOF
)

COMMIT=
while getopts :c:h OPT ; do
	case "$OPT" in
	c)	COMMIT=$OPTARG ;;
	h)	echo "$HELP" ; exit ;;
	*)	echo >&2 "error: unknown option -$OPTARG" ; exit 1 ;;
	esac
done
shift "$((OPTIND-1))"

git status || exit $?
[ -z "$COMMIT" ] && COMMIT=main

git diff -U0 "$COMMIT" -- "$@" | awk '
/^\+\+\+ b\// { file = substr($0, 7) }
/^@@/ {
    gsub(/.*\+/, "", $3);
    gsub(/[^0-9,].*/, "", $3);
    split($3, a, ",");
    start = a[1];
    count = (a[2] ? a[2] : 1);
    end = start + count - 1;
    print file " " start " " end
}'
